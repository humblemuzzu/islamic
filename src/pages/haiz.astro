import TopicHeader from '../components/TopicHeader.astro';
import MasailList from '../components/MasailList.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const masail = [
  {
    question: {
      en: 'What is the minimum duration of haiz?',
      ru: 'Haiz ki kam se kam muddat kya hai?',
      ur: 'حیض کی کم سے کم مدت کیا ہے؟',
    },
    answer: {
      en: 'The minimum duration of haiz (menstruation) is 3 days and 3 nights, which equals 72 hours. If bleeding lasts less than 72 complete hours, it is not considered haiz — it is istihaza (irregular bleeding). In that case, the woman must make up any salah she missed during those days.',
      ru: 'Haiz ki kam se kam muddat 3 din aur 3 raatein hai, yaani 72 ghantay. Agar khoon 72 ghantay se kam aaye to yeh haiz nahi — yeh istihaza (ghair mamool khoon) hai. Is soorat mein aurat ko un dinon ki chhooti hui salah ki qaza karni hogi.',
      ur: 'حیض کی کم سے کم مدت ۳ دن اور ۳ راتیں ہے، یعنی ۷۲ گھنٹے۔ اگر خون ۷۲ گھنٹے سے کم آئے تو یہ حیض نہیں — یہ استحاضہ (غیر معمول خون) ہے۔ اس صورت میں عورت کو ان دنوں کی چھوٹی ہوئی نماز کی قضا کرنی ہوگی۔',
    },
    reference: 'Nurul Idah, Maraqi al-Falah',
    important: true,
  },
  {
    question: {
      en: 'What is the maximum duration of haiz?',
      ru: 'Haiz ki zyada se zyada muddat kya hai?',
      ur: 'حیض کی زیادہ سے زیادہ مدت کیا ہے؟',
    },
    answer: {
      en: 'The maximum duration of haiz is 10 days and 10 nights, which equals 240 hours. If bleeding continues beyond 10 days, the excess is not haiz. The woman should refer to her established habit (\'aadah) to determine which days were haiz and which were istihaza.',
      ru: 'Haiz ki zyada se zyada muddat 10 din aur 10 raatein hai, yaani 240 ghantay. Agar khoon 10 din se zyada aaye to jo zyada hai woh haiz nahi. Aurat ko apni purani aadat (\'aadah) dekh kar faisla karna chahiye ke kaunse din haiz the aur kaunse istihaza.',
      ur: 'حیض کی زیادہ سے زیادہ مدت ۱۰ دن اور ۱۰ راتیں ہے، یعنی ۲۴۰ گھنٹے۔ اگر خون ۱۰ دن سے زیادہ آئے تو جو زیادہ ہے وہ حیض نہیں۔ عورت کو اپنی پرانی عادت دیکھ کر فیصلہ کرنا چاہیے کہ کون سے دن حیض تھے اور کون سے استحاضہ۔',
    },
    reference: 'Nurul Idah, Al-Hidayah',
    important: true,
  },
  {
    question: {
      en: 'What if I have no established habit and bleeding exceeds 10 days?',
      ru: 'Agar meri koi purani aadat nahi aur khoon 10 din se zyada aaye to?',
      ur: 'اگر میری کوئی پرانی عادت نہیں اور خون ۱۰ دن سے زیادہ آئے تو؟',
    },
    answer: {
      en: 'If a woman has no previously established habit (such as someone experiencing haiz for the first time or cannot remember her pattern), then 10 days are counted as haiz and anything beyond that is istihaza. She should perform ghusl after 10 days and resume salah.',
      ru: 'Agar aurat ki koi pehle se aadat nahi hai (jaise pehli baar haiz aa raha ho ya apna pattern yaad na ho), to 10 din haiz shumaar honge aur us ke baad ka khoon istihaza hoga. Usse 10 din ke baad ghusl kar ke salah shuru karni chahiye.',
      ur: 'اگر عورت کی کوئی پہلے سے عادت نہیں ہے (جیسے پہلی بار حیض آ رہا ہو یا اپنا معمول یاد نہ ہو)، تو ۱۰ دن حیض شمار ہوں گے اور اس کے بعد کا خون استحاضہ ہوگا۔ اسے ۱۰ دن کے بعد غسل کر کے نماز شروع کرنی چاہیے۔',
    },
    reference: 'Al-Hidayah',
  },
  {
    question: {
      en: 'Can haiz start and stop within the 3 to 10 day window?',
      ru: 'Kya haiz 3 se 10 din ke andar shuru aur band ho sakta hai?',
      ur: 'کیا حیض ۳ سے ۱۰ دن کے اندر شروع اور بند ہو سکتا ہے؟',
    },
    answer: {
      en: 'Yes. If bleeding starts and stops intermittently within the 3-10 day window, the entire period from the start of bleeding to the end (including dry gaps in between) is considered haiz, as long as the total span does not exceed 10 days. The dry days in between are also counted as part of haiz.',
      ru: 'Haan. Agar khoon 3 se 10 din ke andar aat-jaat karta rahe (beech mein ruk ke phir aaye), to shuru se aakhir tak ka poora arsa haiz mein shumaar hoga, jab tak ke poori muddat 10 din se na badhay. Beech ke khushk din bhi haiz ka hissa honge.',
      ur: 'ہاں۔ اگر خون ۳ سے ۱۰ دن کے اندر آتا جاتا رہے (بیچ میں رک کر پھر آئے)، تو شروع سے آخر تک کا پورا عرصہ حیض میں شمار ہوگا، جب تک کہ پوری مدت ۱۰ دن سے نہ بڑھے۔ بیچ کے خشک دن بھی حیض کا حصہ ہوں گے۔',
    },
    reference: 'Nurul Idah',
  },
  {
    question: {
      en: 'What is the minimum gap of purity (tuhr) between two haiz periods?',
      ru: 'Do haiz ke darmiyan paaki (tuhr) ka kam se kam waqfa kitna hai?',
      ur: 'دو حیض کے درمیان پاکی (طہر) کا کم سے کم وقفہ کتنا ہے؟',
    },
    answer: {
      en: 'The minimum tuhr (purity) between two valid haiz periods is 15 days. If bleeding returns before 15 complete clean days have passed, the second bleeding is istihaza, NOT a new haiz. For example: if haiz lasted 8 days, and after only 8 clean days bleeding starts again — the second bleeding is istihaza because the 15-day minimum gap was not met.',
      ru: 'Do haiz ke darmiyan tuhr (paaki) ki kam se kam muddat 15 din hai. Agar 15 saaf din poore hone se pehle khoon wapas aa jaye, to doosra khoon istihaza hai, naya haiz NAHI. Misal ke taur par: agar haiz 8 din raha, aur sirf 8 saaf dinon ke baad phir khoon aaye — to doosra khoon istihaza hai kyunke 15 din ka waqfa poora nahi hua.',
      ur: 'دو حیض کے درمیان طہر (پاکی) کی کم سے کم مدت ۱۵ دن ہے۔ اگر ۱۵ صاف دن پورے ہونے سے پہلے خون واپس آ جائے، تو دوسرا خون استحاضہ ہے، نیا حیض نہیں۔ مثال کے طور پر: اگر حیض ۸ دن رہا، اور صرف ۸ صاف دنوں کے بعد پھر خون آئے — تو دوسرا خون استحاضہ ہے کیونکہ ۱۵ دن کا وقفہ پورا نہیں ہوا۔',
    },
    reference: 'Nurul Idah, Al-Hidayah',
    important: true,
  },
  {
    question: {
      en: 'Is there a maximum for the period of purity (tuhr) between two haiz cycles?',
      ru: 'Kya do haiz ke darmiyan paaki (tuhr) ki koi zyada se zyada hadd hai?',
      ur: 'کیا دو حیض کے درمیان پاکی (طہر) کی کوئی زیادہ سے زیادہ حد ہے؟',
    },
    answer: {
      en: 'No. There is no maximum for tuhr. A woman may go months or even years without haiz (such as during pregnancy, breastfeeding, or due to medical conditions), and this is perfectly normal from a fiqh perspective.',
      ru: 'Nahi. Tuhr ki koi zyada se zyada hadd nahi hai. Aurat mahino ya saalon tak bina haiz ke reh sakti hai (jaise hamal, doodh pilane, ya kisi medical wajah se), aur yeh fiqh ke mutabiq bilkul normal hai.',
      ur: 'نہیں۔ طہر کی کوئی زیادہ سے زیادہ حد نہیں ہے۔ عورت مہینوں یا سالوں تک بغیر حیض کے رہ سکتی ہے (جیسے حمل، دودھ پلانے، یا کسی طبی وجہ سے)، اور یہ فقہ کے مطابق بالکل نارمل ہے۔',
    },
    reference: 'Radd al-Muhtar',
  },
  {
    question: {
      en: 'What colour of blood counts as haiz?',
      ru: 'Haiz mein khoon ka kaun sa rang shumaar hota hai?',
      ur: 'حیض میں خون کا کون سا رنگ شمار ہوتا ہے؟',
    },
    answer: {
      en: 'In the Hanafi school, haiz blood can be any of the following <strong>six colours</strong> as mentioned in Bahar-e-Shariat: (1) Black (siyah), (2) Red (surkh), (3) Green (sabz), (4) Yellow (zard), (5) Turbid/muddy (gadla), (6) Earthy/dust-coloured (matila). All of these are valid colours for menstrual blood. <strong>White discharge is NOT haiz</strong> — it is a sign of purity (tuhr). As long as the bleeding meets the duration and tuhr requirements, it is haiz regardless of which of these six colours it is.',
      ru: 'Hanafi mazhab mein haiz ka khoon Bahar-e-Shariat ke mutabiq in <strong>chhe rangon</strong> mein se koi bhi ho sakta hai: (1) Kaala (siyah), (2) Surkh (laal), (3) Sabz (hara), (4) Zard (peela), (5) Gadla (maila), (6) Matila (mitti ke rang jaisa). Yeh sab rang haiz ke khoon ke liye durust hain. <strong>Safed discharge haiz NAHI hai</strong> — yeh paaki (tuhr) ki nishani hai. Jab tak khoon muddat aur tuhr ki sharaitein poori kare, yeh haiz hai chahe rang kuch bhi ho.',
      ur: 'حنفی مذہب میں حیض کا خون بہارِ شریعت کے مطابق ان <strong>چھ رنگوں</strong> میں سے کوئی بھی ہو سکتا ہے: (۱) کالا (سیاہ)، (۲) سرخ (لال)، (۳) سبز (ہرا)، (۴) زرد (پیلا)، (۵) گدلا (میلا)، (۶) مٹیلا (مٹی کے رنگ جیسا)۔ یہ سب رنگ حیض کے خون کے لیے درست ہیں۔ <strong>سفید ڈسچارج حیض نہیں ہے</strong> — یہ پاکی (طہر) کی نشانی ہے۔ جب تک خون مدت اور طہر کی شرائط پوری کرے، یہ حیض ہے چاہے رنگ کچھ بھی ہو۔',
    },
    reference: 'Bahar-e-Shariat, Nurul Idah',
  },
  {
    question: {
      en: 'What if my habit changes — e.g., it was 7 days but this time it is 9?',
