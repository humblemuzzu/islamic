---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const pdfs = [
  {
    id: 'ramadan-planner',
    url: 'https://github.com/humblemuzzu/islamic/releases/download/resources-v1.0/Hanafi.Girl.Ramadan.Planner.pdf',
    coverText: 'Ramadan Planner',
    title: {
      en: 'Hanafi Girl Ramadan Planner',
      ru: 'Hanafi Girl Ramadan Planner',
      ur: 'حنفی گرل رمضان پلانر',
    },
    description: {
      en: 'Complete 30-day Ramadan planner with daily dhikr schedule, Qurani suraten, Arabic & Urdu duas, and daily routine tracker.',
      ru: 'Mukammal 30 din ka Ramadan planner jismein rozana dhikr, Qurani suraten, Arabi aur Urdu duaein, aur rozana mamool tracker shamil hai.',
      ur: 'مکمل ۳۰ دن کا رمضان پلانر جس میں روزانہ ذکر، قرآنی سورتیں، عربی اور اردو دعائیں، اور روزانہ معمول ٹریکر شامل ہے۔',
    },
    meta: '203 pages  ~20 MB',
  },
  {
    id: 'wazaif-1-10',
    url: 'https://github.com/humblemuzzu/islamic/releases/download/resources-v1.0/Ramzan.Wazaif.1.to.10.Roza.pdf',
    coverText: 'Wazaif 1-10',
    title: {
      en: 'Ramzan Wazaif — Days 1 to 10',
      ru: 'Ramzan Wazaif — 1 Se 10 Roza',
      ur: 'رمضان وظائف — ۱ سے ۱۰ روزہ',
    },
    description: {
      en: 'Daily wazaif after each namaz with specific duas and Qurani ayaat for the first 10 days of Ramadan (1st Ashra — Rehmat).',
      ru: 'Ramadan ke pehle 10 dinon ke liye har namaz ke baad makhsoos wazaif, duaein aur Qurani ayaat (Pehla Ashra — Rehmat).',
      ur: 'رمضان کے پہلے ۱۰ دنوں کے لیے ہر نماز کے بعد مخصوص وظائف، دعائیں اور قرآنی آیات (پہلا عشرہ — رحمت)۔',
    },
    meta: '214 pages  ~21 MB',
  },
  {
    id: 'wazaif-11-20',
    url: 'https://github.com/humblemuzzu/islamic/releases/download/resources-v1.0/Ramzan_Wazaif_11_to_20_Roza.pdf',
    coverText: 'Wazaif 11-20',
    title: {
      en: 'Ramzan Wazaif — Days 11 to 20',
      ru: 'Ramzan Wazaif — 11 Se 20 Roza',
      ur: 'رمضان وظائف — ۱۱ سے ۲۰ روزہ',
    },
    description: {
      en: 'Continued daily wazaif including Salaatut Tasbih guide, specific duas, and Qurani ayaat for days 11-20 (2nd Ashra — Magfirat).',
      ru: 'Aglay 10 dinon ke wazaif jismein Salaatut Tasbih ki guide, makhsoos duaein, aur Qurani ayaat shamil hain (Doosra Ashra — Magfirat).',
      ur: 'اگلے ۱۰ دنوں کے وظائف جس میں صلاۃ التسبیح کی گائیڈ، مخصوص دعائیں، اور قرآنی آیات شامل ہیں (دوسرا عشرہ — مغفرت)۔',
    },
    meta: '366 pages  ~36 MB',
  },
  {
    id: 'durood-shareef',
    url: 'https://github.com/humblemuzzu/islamic/releases/download/resources-v1.0/Ashar.For.Durood.Shareef.pdf',
    coverText: 'Durood Shareef',
    title: {
      en: 'Ashar for Durood Shareef',
      ru: 'Ashar for Durood Shareef',
      ur: 'اشعار درود شریف',
    },
    description: {
      en: 'A beautiful collection of Durood Shareef with Ashar (poetry) in praise of Prophet Muhammad (peace be upon him).',
      ru: 'Nabi Kareem (sallallahu alaihi wasallam) ki shan mein Durood Shareef ka khubsurat majmooa ashar ke saath.',
      ur: 'نبی کریم صلی اللہ علیہ وسلم کی شان میں درود شریف کا خوبصورت مجموعہ اشعار کے ساتھ۔',
    },
    meta: 'PDF',
  },
  {
    id: 'qaseeda-burdaa',
    url: 'https://github.com/humblemuzzu/islamic/releases/download/resources-v1.0/Qaseeda.Burdaa.Sharif.pdf',
    coverText: 'Qaseeda Burdaa',
    title: {
      en: 'Qaseeda Burdaa Sharif',
      ru: 'Qaseeda Burdaa Sharif',
      ur: 'قصیدہ بردہ شریف',
    },
    description: {
      en: 'The famous Qaseeda Burdaa — a masterpiece of Arabic poetry in praise of Prophet Muhammad (peace be upon him) by Imam al-Busiri.',
      ru: 'Mashoor Qaseeda Burdaa — Imam al-Busiri ki Nabi Kareem (sallallahu alaihi wasallam) ki shan mein Arabi sha\'iri ka shaahkaar.',
      ur: 'مشہور قصیدہ بردہ — امام البوصیری کی نبی کریم صلی اللہ علیہ وسلم کی شان میں عربی شاعری کا شاہکار۔',
    },
    meta: 'PDF',
  },
];
---

<Layout title="Downloads | Al-Masail">
  <Navbar />
  <main>
    <!-- Hero Section -->
    <section class="dl-hero">
      <div class="pattern-overlay"></div>
      <div class="pattern-star"></div>

      <div class="dl-hero-content container">
        <div class="dl-title-block reveal reveal-delay-1">
          <span class="section-label">MAKTABA</span>
          <h1 class="dl-title-ar">المَكْتَبَة</h1>
          <h2 class="dl-title-en">DOWNLOADS</h2>
        </div>

        <div class="dl-desc reveal reveal-delay-2">
          <p data-lang-block="en">Free Islamic resources for your spiritual journey — download planners, wazaif guides, and more.</p>
          <p data-lang-block="ru">Aapke roohani safar ke liye mufat Islami wasail — planners, wazaif guides, aur bahut kuch download karein.</p>
          <p data-lang-block="ur">آپ کے روحانی سفر کے لیے مفت اسلامی وسائل — پلانرز، وظائف گائیڈز، اور بہت کچھ ڈاؤن لوڈ کریں۔</p>
        </div>

        <div class="dl-meta reveal reveal-delay-3">
          <span class="meta-count">5 <T en="Resources" ru="Resources" ur="وسائل" /></span>
        </div>
      </div>

      <div class="dl-hero-border">
        <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
          <line x1="0" y1="1" x2="1200" y2="1" stroke="url(#goldLineDl)" stroke-width="1" stroke-dasharray="8 12 3 12" />
          <defs>
            <linearGradient id="goldLineDl">
              <stop offset="0%" stop-color="transparent" />
              <stop offset="30%" stop-color="#C4A265" />
              <stop offset="70%" stop-color="#C4A265" />
              <stop offset="100%" stop-color="transparent" />
            </linearGradient>
          </defs>
        </svg>
      </div>
    </section>

    <!-- PDF Grid Section -->
    <section class="dl-grid-section">
      <div class="container">
        <div class="dl-grid">
          {pdfs.map((pdf, i) => (
            <div class={`dl-card reveal reveal-delay-${(i % 5) + 1}${i === pdfs.length - 1 ? ' dl-card-full' : ''}`}>
              <div class="book-cover">
                <div class="book-spine"></div>
                <div class="book-pattern"></div>
                <div class="book-inner-border"></div>
                <span class="book-title">{pdf.coverText}</span>
                <div class="book-ornament">✦</div>
              </div>
              <div class="dl-card-body">
                <h3 class="dl-card-title">
                  <span data-lang-text="en">{pdf.title.en}</span>
                  <span data-lang-text="ru">{pdf.title.ru}</span>
                  <span data-lang-text="ur">{pdf.title.ur}</span>
                </h3>
                <p class="dl-card-desc" data-lang-block="en">{pdf.description.en}</p>
                <p class="dl-card-desc" data-lang-block="ru">{pdf.description.ru}</p>
                <p class="dl-card-desc" data-lang-block="ur">{pdf.description.ur}</p>
                <div class="dl-card-footer">
                  <span class="dl-meta-pill">{pdf.meta}</span>
                  <a href={pdf.url} class="dl-btn" download>
                    <svg viewBox="0 0 20 20" fill="none" class="dl-btn-icon">
                      <path d="M10 3v10m0 0l-3.5-3.5M10 13l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M3 15v1a2 2 0 002 2h10a2 2 0 002-2v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <T en="Download PDF" ru="Download PDF" ur="پی ڈی ایف ڈاؤن لوڈ" />
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* ========================================
     Hero Section
     ======================================== */

  .dl-hero {
    position: relative;
    padding: 8rem 0 3.5rem;
    background: linear-gradient(175deg, var(--ivory) 0%, var(--ivory-deep) 50%, var(--cream) 100%);
    overflow: hidden;
    text-align: center;
  }

  .dl-hero-content {
    position: relative;
    z-index: 2;
  }

  .dl-title-block {
    margin-bottom: var(--space-lg);
  }

  .dl-title-block .section-label {
    display: block;
    margin-bottom: var(--space-sm);
  }

  .dl-title-ar {
    font-family: var(--font-arabic);
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    color: var(--teal-deep);
    direction: rtl;
    line-height: 1.1;
    margin-bottom: var(--space-xs);
  }

  .dl-title-en {
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    font-weight: 300;
    color: var(--text-light);
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .dl-desc {
    max-width: 560px;
    margin: 0 auto var(--space-lg);
  }

  .dl-desc p {
    font-size: clamp(0.92rem, 1.5vw, 1.05rem);
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.8;
  }

  .dl-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-size: 0.82rem;
    color: var(--text-light);
  }

  .meta-count {
    font-weight: 600;
    color: var(--teal);
  }

  .dl-hero-border {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
  }

  .dl-hero-border svg {
    width: 100%;
    height: 2px;
  }

  /* ========================================
     PDF Grid Section
     ======================================== */

  .dl-grid-section {
    background: var(--ivory);
    padding: var(--space-3xl) 0;
  }

  .dl-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .dl-card-full {
    grid-column: 1 / -1;
    max-width: 580px;
    justify-self: center;
    width: 100%;
  }

  /* ========================================
     PDF Card
     ======================================== */

  .dl-card {
    background: var(--white);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
    position: relative;
  }

  .dl-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--gold));
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
  }

  .dl-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-elevated);
  }

  .dl-card:hover::before {
    opacity: 1;
  }

  /* ========================================
     Book Cover (CSS-only)
     ======================================== */

  .book-cover {
    position: relative;
    aspect-ratio: 3 / 2.2;
    background: linear-gradient(145deg, var(--teal) 0%, var(--teal-deep) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .book-spine {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 6px;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.15) 50%, rgba(0, 0, 0, 0.3) 100%);
    z-index: 3;
  }

  .book-spine::after {
    content: '';
    position: absolute;
    top: 0;
    right: -3px;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.03) 100%);
  }

  .book-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 10px,
        rgba(196, 162, 101, 0.5) 10px,
        rgba(196, 162, 101, 0.5) 11px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 10px,
        rgba(196, 162, 101, 0.5) 10px,
        rgba(196, 162, 101, 0.5) 11px
      );
    pointer-events: none;
  }

  .book-inner-border {
    position: absolute;
    inset: 12px 12px 12px 18px;
    border: 1px solid rgba(196, 162, 101, 0.25);
    border-radius: 2px;
    pointer-events: none;
  }

  .book-inner-border::before {
    content: '';
    position: absolute;
    inset: 3px;
    border: 1px solid rgba(196, 162, 101, 0.12);
    border-radius: 1px;
  }

  .book-title {
    position: relative;
    z-index: 2;
    font-family: var(--font-arabic);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 700;
    color: var(--gold-light);
    text-align: center;
    letter-spacing: 0.05em;
    line-height: 1.4;
    padding: 0 var(--space-xl);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .book-ornament {
    position: relative;
    z-index: 2;
    color: var(--gold);
    font-size: 0.75rem;
    margin-top: var(--space-sm);
    opacity: 0.5;
  }

  /* ========================================
     Card Body
     ======================================== */

  .dl-card-body {
    padding: var(--space-lg) var(--space-lg) var(--space-xl);
  }

  .dl-card-title {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    font-weight: 600;
    color: var(--teal-deep);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
  }

  .dl-card-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .dl-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .dl-meta-pill {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--text-light);
    background: var(--ivory-deep);
    padding: 0.3em 0.8em;
    border-radius: var(--radius-xl);
  }

  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--teal);
    color: var(--ivory);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.6em 1.4em;
    border-radius: var(--radius-sm);
    transition: transform 0.4s var(--ease-out), background 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }

  .dl-btn:hover {
    transform: translateY(-2px);
    background: var(--teal-deep);
    box-shadow: 0 4px 16px rgba(26, 92, 82, 0.25);
  }

  .dl-btn-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* ========================================
     Responsive
     ======================================== */

  @media (max-width: 768px) {
    .dl-grid {
      grid-template-columns: 1fr;
    }

    .dl-card-full {
      max-width: none;
    }

    .book-cover {
      aspect-ratio: 3 / 1.8;
    }
  }

  @media (max-width: 640px) {
    .dl-card-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .dl-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
