---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import TopicHeader from '../components/TopicHeader.astro';
import MasailList from '../components/MasailList.astro';
import Footer from '../components/Footer.astro';
import { taharahMasail } from '../content/masail/taharah';
import '../styles/global.css';
---


<Layout title="Taharah — Purification | Al-Masail">
  <Navbar />
  <main>
    <TopicHeader
      titleAr="طَهَارَة"
      titleEn="Taharah — Purification"
      subtitle={{
        en: 'Purification',
        ru: 'Tahaarat ke Masail',
        ur: 'طہارت کے مسائل',
      }}
      description={{
        en: 'Wudu, ghusl, and purity rulings specific to women — what breaks wudu, how to perform ghusl, and common questions.',
        ru: 'Wuzu, ghusl, aur paaki ke ahkaam jo khawateen se mutalliq hain — wuzu kya todta hai, ghusl ka tareeqa, aur aam sawalaat.',
        ur: 'وضو، غسل، اور پاکی کے احکام جو خواتین سے متعلق ہیں — وضو کیا توڑتا ہے، غسل کا طریقہ، اور عام سوالات۔',
      }}
      masailCount={taharahMasail.length}
    />
    <MasailList masail={taharahMasail} />
  </main>
  <Footer />
</Layout>
