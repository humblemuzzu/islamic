---
import T from '../T.astro';
---

<div class="ask-loading-inner">
  <div class="loading-book">
    <div class="loading-page page-1"></div>
    <div class="loading-page page-2"></div>
    <div class="loading-page page-3"></div>
  </div>
  <p class="loading-text">
    <T en="Searching through the books..." ru="Kutub mein dhundh rahe hain..." ur="کتب میں ڈھونڈ رہے ہیں..." />
  </p>
  <p class="loading-subtext">
    <T en="This may take a few seconds" ru="Yeh kuch seconds le sakta hai" ur="یہ کچھ سیکنڈ لے سکتا ہے" />
  </p>
</div>
