---
import T from './T.astro';

const categories = [
  {
    id: 'haiz',
    titleAr: 'حَيض',
    titleEn: 'Haiz',
    subtitle: { en: 'Menstruation', ru: 'Haiz ke Masail', ur: 'حیض کے مسائل' },
    description: {
      en: 'Rules regarding the menstrual cycle, minimum & maximum durations, and related rulings.',
      ru: 'Mahawari ke ahkaam, kam se kam aur zyada se zyada muddat, aur mutalliqa masail.',
      ur: 'ماہواری کے احکام، کم سے کم اور زیادہ سے زیادہ مدت، اور متعلقہ مسائل۔'
    },
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="1.5"/><path d="M20 8v24M8 20h24" stroke="currentColor" stroke-width="1" opacity="0.3"/><circle cx="20" cy="20" r="6" stroke="currentColor" stroke-width="1.5"/></svg>`,
    count: 12,
  },
  {
    id: 'istihaza',
    titleAr: 'اِسْتِحَاضَة',
    titleEn: 'Istihaza',
    subtitle: { en: 'Irregular Bleeding', ru: 'Istihaza ke Masail', ur: 'استحاضہ کے مسائل' },
    description: {
      en: 'Understanding istihaza, its distinction from haiz, and prayer rulings during it.',
      ru: 'Istihaza ki pehchaan, haiz se farq, aur is dauraan namaz ke ahkaam.',
      ur: 'استحاضہ کی پہچان، حیض سے فرق، اور اس دوران نماز کے احکام۔'
    },
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 4L20 36" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3"/><circle cx="20" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="28" r="4" stroke="currentColor" stroke-width="1.5"/></svg>`,
    count: 8,
  },
  {
    id: 'nifas',
    titleAr: 'نِفَاس',
    titleEn: 'Nifas',
    subtitle: { en: 'Post-Natal Bleeding', ru: 'Nifas ke Masail', ur: 'نفاس کے مسائل' },
    description: {
      en: 'Rulings on post-childbirth bleeding, maximum duration, and when to resume salah.',
      ru: 'Wiladat ke baad khoon ke ahkaam, zyada se zyada muddat, aur namaz kab shuru karein.',
      ur: 'ولادت کے بعد خون کے احکام، زیادہ سے زیادہ مدت، اور نماز کب شروع کریں۔'
    },
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 6c-8 10-14 16-14 22a14 14 0 0028 0c0-6-6-12-14-22z" stroke="currentColor" stroke-width="1.5"/></svg>`,
    count: 8,
  },
  {
    id: 'salah',
    titleAr: 'صَلَاة',
    titleEn: 'Salah',
    subtitle: { en: 'Prayer', ru: 'Namaz ke Masail', ur: 'نماز کے مسائل' },
    description: {
      en: 'Women-specific rulings on prayer, including posture differences and makeup prayers.',
      ru: 'Khawateen ke liye namaz ke khaas ahkaam, tareeqa aur qaza namaz.',
      ur: 'خواتین کے لیے نماز کے خاص احکام، طریقہ اور قضا نماز۔'
    },
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 4v8M20 28v8M4 20h8M28 20h8" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="8" stroke="currentColor" stroke-width="1.5"/></svg>`,
    count: 10,
  },
  {
    id: 'sawm',
    titleAr: 'صَوم',
    titleEn: 'Sawm',
    subtitle: { en: 'Fasting', ru: 'Roze ke Masail', ur: 'روزے کے مسائل' },
    description: {
      en: 'Fasting rulings during menstruation, making up missed fasts, and related questions.',
      ru: 'Haiz mein roze ke ahkaam, chhoote hue rozon ki qaza, aur mutalliqa sawalaat.',
      ur: 'حیض میں روزے کے احکام، چھوٹے ہوئے روزوں کی قضا، اور متعلقہ سوالات۔'
    },
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M26 8a12 12 0 100 24 12 12 0 01-12-12A12 12 0 0126 8z" stroke="currentColor" stroke-width="1.5"/></svg>`,
    count: 9,
  },
  {
    id: 'taharah',
    titleAr: 'طَهَارَة',
    titleEn: 'Taharah',
    subtitle: { en: 'Purification', ru: 'Tahaarat ke Masail', ur: 'طہارت کے مسائل' },
    description: {
      en: 'Wudu, ghusl, and purity rulings specific to women in the Hanafi school.',
      ru: 'Wuzu, ghusl, aur paaki ke ahkaam jo khawateen se mutalliq hain, Hanafi maslak ke mutabiq.',
      ur: 'وضو، غسل، اور پاکی کے احکام جو خواتین سے متعلق ہیں، حنفی مسلک کے مطابق۔'
    },
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 4l4 12h-8l4-12z" stroke="currentColor" stroke-width="1.5"/><path d="M12 24c0 4.4 3.6 8 8 8s8-3.6 8-8" stroke="currentColor" stroke-width="1.5"/><path d="M12 24h16" stroke="currentColor" stroke-width="1"/></svg>`,
    count: 9,
  },
];
---

<section class="categories" id="categories">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label"><T en="Browse by Topic" ru="Mauzu' ke hisab se" ur="موضوع کے حساب سے" /></span>
      <p class="section-title-ar">أبْوَاب المَسَائِل</p>
      <h2 class="section-title"><T en="Chapters of Masail" ru="Masail ke Abwab" ur="مسائل کے ابواب" /></h2>
    </div>

    <div class="categories-grid">
      {categories.map((cat, i) => (
        <a href={`/${cat.id}`} class={`category-card reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="card-icon" set:html={cat.icon} />
          <div class="card-body">
            <div class="card-title-row">
              <span class="card-title-ar">{cat.titleAr}</span>
              <h3 class="card-title-en">{cat.titleEn}</h3>
            </div>
            <p class="card-subtitle">
              <span data-lang-text="en">{cat.subtitle.en}</span>
              <span data-lang-text="ru">{cat.subtitle.ru}</span>
              <span data-lang-text="ur">{cat.subtitle.ur}</span>
            </p>
            <p class="card-desc">
              <span data-lang-text="en">{cat.description.en}</span>
              <span data-lang-text="ru">{cat.description.ru}</span>
              <span data-lang-text="ur">{cat.description.ur}</span>
            </p>
          </div>
          <div class="card-footer">
            <span class="card-count">
              <span data-lang-text="en">{cat.count} masail</span>
              <span data-lang-text="ru">{cat.count} masail</span>
              <span data-lang-text="ur">{cat.count} مسائل</span>
            </span>
            <span class="card-arrow">&rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .categories {
    padding: var(--space-4xl) 0;
    background: var(--white);
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .section-header .section-label {
    display: block;
    margin-bottom: var(--space-sm);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .category-card {
    display: flex;
    flex-direction: column;
    background: var(--ivory);
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: all 0.4s var(--ease-out);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .category-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--gold));
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .category-card:hover {
    border-color: var(--sand);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }

  .category-card:hover::before {
    opacity: 1;
  }

  .card-icon {
    width: 40px;
    height: 40px;
    color: var(--teal);
    margin-bottom: var(--space-lg);
    transition: color 0.3s ease;
  }

  .category-card:hover .card-icon {
    color: var(--gold);
  }

  .card-body {
    flex: 1;
  }

  .card-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .card-title-ar {
    font-family: var(--font-arabic);
    font-size: 1.15rem;
    color: var(--gold);
    direction: rtl;
  }

  .card-title-en {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--teal-deep);
  }

  .card-subtitle {
    font-size: 0.8rem;
    color: var(--text-light);
    margin-bottom: var(--space-md);
    font-weight: 400;
  }

  .card-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--cream);
  }

  .card-count {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-light);
    letter-spacing: 0.02em;
  }

  .card-arrow {
    color: var(--teal);
    font-size: 1.1rem;
    transition: transform 0.3s var(--ease-out);
  }

  .category-card:hover .card-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .categories-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .category-card {
      padding: var(--space-lg);
    }
  }
</style>
