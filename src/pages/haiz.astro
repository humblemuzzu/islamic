---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import TopicHeader from '../components/TopicHeader.astro';
import MasailList from '../components/MasailList.astro';
import Footer from '../components/Footer.astro';
import { haizMasail } from '../content/masail/haiz';
import '../styles/global.css';
---

<Layout title="Haiz — Menstruation | Al-Masail">
  <Navbar />
  <main>
    <TopicHeader
      titleAr="حَيض"
      titleEn="Haiz — Menstruation"
      subtitle={{
        en: 'Menstruation',
        ru: 'Haiz',
        ur: 'حیض',
      }}
      description={{
        en: 'Complete rulings regarding the menstrual cycle in the Hanafi school — durations, purity gaps, what is permitted and what is not.',
        ru: 'Hanafi mazhab mein haiz ke mukammal ahkaam — muddat, paaki ka waqfa, kya jaiz hai aur kya nahi.',
        ur: 'حنفی مذہب میں حیض کے مکمل احکام — مدت، پاکی کا وقفہ، کیا جائز ہے اور کیا نہیں۔',
      }}
      masailCount={haizMasail.length}
    />
    <MasailList masail={haizMasail} />
  </main>
  <Footer />
</Layout>
