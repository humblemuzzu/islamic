---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SawalHero from '../components/sawal/SawalHero.astro';
import CategorySelector from '../components/sawal/CategorySelector.astro';
import HaizFlowBleeding from '../components/sawal/HaizFlowBleeding.astro';
import HaizFlowEnded from '../components/sawal/HaizFlowEnded.astro';
import HaizFlowSpecial from '../components/sawal/HaizFlowSpecial.astro';
import IstihazaFlow from '../components/sawal/IstihazaFlow.astro';
import NifasFlow from '../components/sawal/NifasFlow.astro';
import SalahFlow from '../components/sawal/SalahFlow.astro';
import SawmFlow from '../components/sawal/SawmFlow.astro';
import GhuslFlow from '../components/sawal/GhuslFlow.astro';
import QuranFlow from '../components/sawal/QuranFlow.astro';
import MasjidFlow from '../components/sawal/MasjidFlow.astro';
import ZawajFlow from '../components/sawal/ZawajFlow.astro';
import '../styles/global.css';
import '../styles/sawal.css';
---

<Layout title="Fori Sawal — Interactive Fiqh Guide | Al-Masail">
  <Navbar />
  <main>
    <SawalHero />

    <section class="sawal-interactive">
      <div class="container sawal-container">
        <CategorySelector />

        <div class="qa-container" id="qaContainer" style="display: none;">
          <div class="qa-progress">
            <div class="qa-progress-bar" id="qaProgressBar"></div>
          </div>
          <div class="qa-panel" id="qaPanel">
            <HaizFlowBleeding />
            <HaizFlowEnded />
            <HaizFlowSpecial />
            <IstihazaFlow />
            <NifasFlow />
            <SalahFlow />
            <SawmFlow />
            <GhuslFlow />
            <QuranFlow />
            <MasjidFlow />
            <ZawajFlow />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/sawal-engine.ts';
</script>
