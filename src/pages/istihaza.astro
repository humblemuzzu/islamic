---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import TopicHeader from '../components/TopicHeader.astro';
import MasailList from '../components/MasailList.astro';
import Footer from '../components/Footer.astro';
import { istihazaMasail } from '../content/masail/istihaza';
import '../styles/global.css';
---


<Layout title="Istihaza — Irregular Bleeding | Al-Masail">
  <Navbar />
  <main>
    <TopicHeader
      titleAr="اِسْتِحَاضَة"
      titleEn="Istihaza — Irregular Bleeding"
      subtitle={{ en: 'Irregular Bleeding', ru: 'Istihaza ke Masail', ur: 'استحاضہ کے مسائل' }}
      description={{ en: 'Understanding istihaza, how it differs from haiz, and the rulings that apply — especially regarding salah and fasting.', ru: 'Istihaza ki pehchaan, haiz se farq, aur is se mutaliq ahkaam — khaas taur par namaz aur roze ke baare mein.', ur: 'استحاضہ کی پہچان، حیض سے فرق، اور اس سے متعلق احکام — خاص طور پر نماز اور روزے کے بارے میں۔' }}
      masailCount={istihazaMasail.length}
    />
    <MasailList masail={istihazaMasail} />
  </main>
  <Footer />
</Layout>
