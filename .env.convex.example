# Project-scoped Convex environment
# Copy to .env.convex.local and fill values.

CONVEX_DEPLOYMENT=dev:curious-moose-985
CONVEX_URL=https://curious-moose-985.convex.cloud
CONVEX_SITE_URL=https://curious-moose-985.convex.site

# Optional but recommended for secure ingestion mutations
CONVEX_INGEST_KEY=replace-with-random-secret

# Keep in sync with actual chunk embedding vectors
CONVEX_EMBEDDING_DIM=1024

# Optional for CI/non-login deploys
CONVEX_DEPLOY_KEY=

# API keys used by Convex actions
GEMINI_API_KEY=
MISTRAL_API_KEY=
