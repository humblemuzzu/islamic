---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
import Footer from '../components/Footer.astro';
import { wazaifData, dhikr3Times, dhikr100Times, dailySurahs } from '../content/ramadan/data';
import '../styles/global.css';
import '../styles/ramadan-layout.css';
import '../styles/ramadan-wazaif.css';
---

<Layout title="Ramadan Guide | Al-Masail">
  <Navbar />
  <main>

    <!-- ========================================
         SECTION 1: RAMADAN HERO
         ======================================== -->
    <section class="ramadan-hero" id="ramadan-hero">
      <div class="pattern-overlay"></div>
      <div class="pattern-star"></div>
      <div class="crescent-decoration"></div>

      <div class="ramadan-hero-content container">
        <div class="hero-bismillah reveal">
          بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ
        </div>

        <div class="hero-title-block reveal reveal-delay-1">
          <h1 class="hero-title-ar">رَمَضَان</h1>
          <span class="hero-title-en">RAMADAN GUIDE</span>
        </div>

        <div class="hero-desc reveal reveal-delay-2">
          <p data-lang-block="en">Your daily companion for a blessed Ramadan — dhikr, wazaif, and daily planner all in one place.</p>
          <p data-lang-block="ru">Aapka rozana ka sathi ek mubarak Ramadan ke liye — dhikr, wazaif, aur rozana ka planner sab ek jagah.</p>
          <p data-lang-block="ur">آپ کا روزانہ کا ساتھی ایک مبارک رمضان کے لیے — ذکر، وظائف، اور روزانہ کا پلانر سب ایک جگہ۔</p>
        </div>

        <div class="hero-cta-row reveal reveal-delay-3">
          <a href="#dhikr" class="hero-pill">
            <T en="Daily Dhikr" ru="Rozana Dhikr" ur="روزانہ ذکر" />
          </a>
          <a href="#wazaif" class="hero-pill">
            <T en="Wazaif" ru="Wazaif" ur="وظائف" />
          </a>
          <a href="#downloads" class="hero-pill">
            <T en="Downloads" ru="Downloads" ur="ڈاؤن لوڈز" />
          </a>
        </div>

        <div class="hero-ornament reveal reveal-delay-4">
          <span class="ornament-dot"></span>
          <span class="ornament-line"></span>
          <span class="ornament-star">&#10022;</span>
          <span class="ornament-line"></span>
          <span class="ornament-dot"></span>
        </div>
      </div>

      <div class="hero-bottom-border">
        <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
          <line x1="0" y1="1" x2="1200" y2="1" stroke="url(#goldLineRamadan)" stroke-width="1" stroke-dasharray="8 12 3 12" />
          <defs>
            <linearGradient id="goldLineRamadan">
              <stop offset="0%" stop-color="transparent" />
              <stop offset="30%" stop-color="#C4A265" />
              <stop offset="70%" stop-color="#C4A265" />
              <stop offset="100%" stop-color="transparent" />
            </linearGradient>
          </defs>
        </svg>
      </div>
    </section>

    <!-- ========================================
         SECTION 2: DAILY DHIKR
         ======================================== -->
    <section class="dhikr-section" id="dhikr">
      <div class="container">
        <div class="section-header reveal">
          <span class="section-label">ROZANA DHIKR</span>
          <h2 class="section-title">
            <T en="Daily Dhikr" ru="Rozana Dhikr" ur="روزانہ ذکر" />
          </h2>
        </div>

        <!-- 3 Times Daily Group -->
        <div class="dhikr-group reveal reveal-delay-1">
          <button class="dhikr-group-header" data-dhikr-toggle="dhikr-3">
            <div class="dhikr-group-title">
              <span class="dhikr-count-badge">3x</span>
              <h3>
                <span data-lang-text="en">Recite Each 3 Times Daily</span>
                <span data-lang-text="ru">Har Ek Zikr Ko 3 Baar Padhein</span>
                <span data-lang-text="ur">ہر ایک ذکر کو ۳ بار پڑھیں</span>
              </h3>
            </div>
            <svg class="dhikr-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="dhikr-group-body open" id="dhikr-3">
            <div class="dhikr-list">
              {dhikr3Times.map((item, i) => (
                <div class="dhikr-item">
                  <span class="dhikr-num">{i + 1}</span>
                  <span class="dhikr-text">
                    <span data-lang-text="en">{item.en}</span>
                    <span data-lang-text="ru">{item.ru}</span>
                    <span data-lang-text="ur" class="dhikr-arabic-text">{item.ur}</span>
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 100 Times Daily Group -->
        <div class="dhikr-group reveal reveal-delay-2">
          <button class="dhikr-group-header" data-dhikr-toggle="dhikr-100">
            <div class="dhikr-group-title">
              <span class="dhikr-count-badge">100x</span>
              <h3>
                <span data-lang-text="en">Recite Each 100 Times Daily</span>
                <span data-lang-text="ru">Har Ek Zikr Ko 100 Baar Padhein</span>
                <span data-lang-text="ur">ہر ایک ذکر کو ۱۰۰ بار پڑھیں</span>
              </h3>
            </div>
            <svg class="dhikr-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="dhikr-group-body open" id="dhikr-100">
            <div class="dhikr-list">
              {dhikr100Times.map((item, i) => (
                <div class="dhikr-item">
                  <span class="dhikr-num">{i + 1}</span>
                  <span class="dhikr-text">
                    <span data-lang-text="en">{item.en}</span>
                    <span data-lang-text="ru">{item.ru}</span>
                    <span data-lang-text="ur" class="dhikr-arabic-text">{item.ur}</span>
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========================================
         SECTION 3: DAILY ROUTINE PLANNER
         ======================================== -->
    <section class="routine-section" id="routine">
      <div class="container">
        <div class="section-header reveal">
          <span class="section-label">ROZANA MAMOOL</span>
          <h2 class="section-title">
            <T en="Daily Routine" ru="Rozana Mamool" ur="روزانہ معمول" />
          </h2>
        </div>

        <div class="routine-grid">
          <!-- Card 1: Fajr to Zohar -->
          <div class="routine-card reveal reveal-delay-1">
            <div class="routine-card-icon">
              <svg viewBox="0 0 32 32" fill="none" stroke="var(--teal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="16" cy="14" r="5" />
                <line x1="16" y1="5" x2="16" y2="7" />
                <line x1="16" y1="21" x2="16" y2="23" />
                <line x1="7" y1="14" x2="9" y2="14" />
                <line x1="23" y1="14" x2="25" y2="14" />
                <line x1="9.6" y1="7.6" x2="11" y2="9" />
                <line x1="21" y1="19" x2="22.4" y2="20.4" />
                <line x1="22.4" y1="7.6" x2="21" y2="9" />
                <line x1="11" y1="19" x2="9.6" y2="20.4" />
                <line x1="4" y1="26" x2="28" y2="26" />
              </svg>
            </div>
            <h3 class="routine-card-title">
              <T en="Fajr to Zohar" ru="Fajr Se Zohar Tak" ur="فجر سے ظہر تک" />
            </h3>
            <ul class="routine-items">
              <li><span data-lang-text="en">1/2 Para Quran</span><span data-lang-text="ru">1/2 Para Quran</span><span data-lang-text="ur">آدھا پارہ قرآن</span></li>
              <li><span data-lang-text="en">Sadqa</span><span data-lang-text="ru">Sadqa</span><span data-lang-text="ur">صدقہ</span></li>
              <li><span data-lang-text="en">Tasbeehat</span><span data-lang-text="ru">Tasbeehat</span><span data-lang-text="ur">تسبیحات</span></li>
              <li><span data-lang-text="en">Durood</span><span data-lang-text="ru">Durood</span><span data-lang-text="ur">دُرُوْد</span></li>
            </ul>
          </div>

          <!-- Card 2: Zohar to Asar -->
          <div class="routine-card reveal reveal-delay-2">
            <div class="routine-card-icon">
              <svg viewBox="0 0 32 32" fill="none" stroke="var(--teal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="16" cy="16" r="6" />
                <line x1="16" y1="4" x2="16" y2="7" />
                <line x1="16" y1="25" x2="16" y2="28" />
                <line x1="4" y1="16" x2="7" y2="16" />
                <line x1="25" y1="16" x2="28" y2="16" />
                <line x1="7.5" y1="7.5" x2="9.6" y2="9.6" />
                <line x1="22.4" y1="22.4" x2="24.5" y2="24.5" />
                <line x1="24.5" y1="7.5" x2="22.4" y2="9.6" />
                <line x1="9.6" y1="22.4" x2="7.5" y2="24.5" />
              </svg>
            </div>
            <h3 class="routine-card-title">
              <T en="Zohar to Asar" ru="Zohar Se Asar Tak" ur="ظہر سے عصر تک" />
            </h3>
            <ul class="routine-items">
              <li><span data-lang-text="en">Surah Yaseen</span><span data-lang-text="ru">Surah Yaseen</span><span data-lang-text="ur">سُوْرَةُ يٰسٓ</span></li>
              <li><span data-lang-text="en">Qaza Namaz</span><span data-lang-text="ru">Qaza Namaz</span><span data-lang-text="ur">قضا نماز</span></li>
              <li><span data-lang-text="en">Astagfar</span><span data-lang-text="ru">Astagfar</span><span data-lang-text="ur">اِسْتِغْفَار</span></li>
            </ul>
          </div>

          <!-- Card 3: Asar to Magrib -->
          <div class="routine-card reveal reveal-delay-3">
            <div class="routine-card-icon">
              <svg viewBox="0 0 32 32" fill="none" stroke="var(--teal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="16" cy="16" r="5" />
                <line x1="16" y1="7" x2="16" y2="9" />
                <line x1="16" y1="23" x2="16" y2="25" />
                <line x1="7" y1="16" x2="9" y2="16" />
                <line x1="23" y1="16" x2="25" y2="16" />
                <line x1="4" y1="26" x2="28" y2="26" />
                <path d="M8 26 C8 22, 12 20, 16 20 C20 20, 24 22, 24 26" stroke="var(--gold)" stroke-width="1" fill="none" opacity="0.5" />
              </svg>
            </div>
            <h3 class="routine-card-title">
              <T en="Asar to Magrib" ru="Asar Se Magrib Tak" ur="عصر سے مغرب تک" />
            </h3>
            <ul class="routine-items">
              <li><span data-lang-text="en">Surah Rahman</span><span data-lang-text="ru">Surah Rahman</span><span data-lang-text="ur">سُوْرَةُ الرَّحْمٰنِ</span></li>
              <li><span data-lang-text="en">Astagfar</span><span data-lang-text="ru">Astagfar</span><span data-lang-text="ur">اِسْتِغْفَار</span></li>
              <li><span data-lang-text="en">Durood</span><span data-lang-text="ru">Durood</span><span data-lang-text="ur">دُرُوْد</span></li>
            </ul>
          </div>

          <!-- Card 4: After Magrib -->
          <div class="routine-card reveal reveal-delay-4">
            <div class="routine-card-icon">
              <svg viewBox="0 0 32 32" fill="none" stroke="var(--teal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16 A8 8 0 1 0 14 8 A5 5 0 0 1 22 16Z" />
                <circle cx="22" cy="8" r="1" fill="var(--gold)" stroke="none" />
                <circle cx="26" cy="12" r="0.7" fill="var(--gold)" stroke="none" />
                <circle cx="24" cy="6" r="0.5" fill="var(--gold)" stroke="none" />
              </svg>
            </div>
            <h3 class="routine-card-title">
              <T en="After Magrib" ru="Magrib Ke Baad" ur="مغرب کے بعد" />
            </h3>
            <ul class="routine-items">
              <li><span data-lang-text="en">Surah Waqia</span><span data-lang-text="ru">Surah Waqia</span><span data-lang-text="ur">سُوْرَةُ الْوَاقِعَةِ</span></li>
              <li><span data-lang-text="en">Surah Mulk</span><span data-lang-text="ru">Surah Mulk</span><span data-lang-text="ur">سُوْرَةُ الْمُلْكِ</span></li>
              <li><span data-lang-text="en">Surah Sajda</span><span data-lang-text="ru">Surah Sajda</span><span data-lang-text="ur">سُوْرَةُ السَّجْدَةِ</span></li>
              <li><span data-lang-text="en">Durood</span><span data-lang-text="ru">Durood</span><span data-lang-text="ur">دُرُوْد</span></li>
            </ul>
          </div>
        </div>

        <!-- Daily Quran Surahs -->
        <div class="quran-surahs-block reveal">
          <div class="divider-ornament">
            <span>&#10022;</span>
          </div>
          <h3 class="quran-surahs-title">
            <T en="Daily Quran Surahs" ru="Rozana Quran Ki Surahein" ur="روزانہ قرآن کی سورتیں" />
          </h3>
          <div class="quran-surahs-list">
            {dailySurahs.map((surah) => (
              <span class="surah-chip">
                <span data-lang-text="en">{surah.en}</span>
                <span data-lang-text="ru">{surah.ru}</span>
                <span data-lang-text="ur" class="surah-chip-ar">{surah.ur}</span>
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ========================================
         SECTION 4: WAZAIF BY DAY
         ======================================== -->
    <section class="wazaif-section" id="wazaif">
      <div class="container">
        <div class="section-header reveal">
          <span class="section-label">WAZAIF</span>
          <h2 class="section-title">
            <T en="Daily Wazaif" ru="Rozana Wazaif" ur="روزانہ وظائف" />
          </h2>
          <p class="wazaif-desc">
            <span data-lang-text="en">Specific wazaif for each day of Ramadan, to be recited after each namaz.</span>
            <span data-lang-text="ru">Ramadan ke har din ke liye makhsoos wazaif, har namaz ke baad padhne hain.</span>
            <span data-lang-text="ur">رمضان کے ہر دن کے لیے مخصوص وظائف، ہر نماز کے بعد پڑھنے ہیں۔</span>
          </p>
        </div>

        <!-- Day Selector -->
        <div class="day-selector reveal reveal-delay-1" id="daySelector">
          {wazaifData.map((w) => (
            <button
              class={`day-btn ${w.day === 1 ? 'active' : ''}`}
              data-day={w.day}
            >
              {w.day}
            </button>
          ))}
        </div>

        <!-- Wazaif Day Cards -->
        <div class="wazaif-cards-container reveal reveal-delay-2">
          {wazaifData.map((w) => (
            <div class={`wazaif-day-card ${w.day === 1 ? 'active' : ''}`} data-wazaif-day={w.day}>
              <div class="wazaif-day-header">
                <div class="wazaif-day-title">
                  <span class="wazaif-day-num">
                    <span data-lang-text="en">Day {w.day}</span>
                    <span data-lang-text="ru">Roza {w.day}</span>
                    <span data-lang-text="ur">روزہ {w.day}</span>
                  </span>
                  <span class={`ashra-badge ashra-${w.ashra}`}>
                    {w.ashra === 1 ? '1st Ashra — Rehmat' : '2nd Ashra — Magfirat'}
                  </span>
                </div>
              </div>

              <div class="wazaif-dua-block">
                <p class="dua-label">
                  <T en="Dua of the Day" ru="Aaj Ki Dua" ur="آج کی دعا" />
                </p>
                <p class="dua-arabic">{w.dua.ar}</p>
                <p class="dua-transliteration">{w.dua.ru}</p>
                <p class="dua-urdu">{w.dua.ur}</p>
              </div>

              <div class="wazaif-schedule">
                <div class="schedule-header-row">
                  <span class="schedule-col-label"><T en="Namaz" ru="Namaz" ur="نماز" /></span>
                  <span class="schedule-col-label"><T en="Wazifa" ru="Wazifa" ur="وظیفہ" /></span>
                  <span class="schedule-col-label"><T en="Count" ru="Ta'adaad" ur="تعداد" /></span>
                </div>
                {w.schedule.map((s) => (
                  <div class="schedule-row">
                    <span class="schedule-namaz">
                      <span class={`namaz-dot namaz-${s.namaz.toLowerCase()}`}></span>
                      {s.namaz}
                    </span>
                    <span class="schedule-wazifa">{s.wazifa}</span>
                    <span class="schedule-count">{s.count || '—'}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========================================
         SECTION 5: DOWNLOAD CTA BANNER
         ======================================== -->
    <section class="download-banner" id="downloads">
      <div class="pattern-overlay"></div>
      <div class="container download-banner-inner">
        <div class="download-text reveal">
          <span data-lang-text="en">Download the complete Ramadan Planner PDF</span>
          <span data-lang-text="ru">Mukammal Ramadan Planner PDF download karein</span>
          <span data-lang-text="ur">مکمل رمضان پلانر پی ڈی ایف ڈاؤن لوڈ کریں</span>
        </div>
        <a href="/downloads" class="download-btn reveal reveal-delay-1">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="download-icon">
            <path d="M10 3v10m0 0l-3.5-3.5M10 13l3.5-3.5M3 17h14" />
          </svg>
          <T en="Download PDF" ru="PDF Download Karein" ur="پی ڈی ایف ڈاؤن لوڈ کریں" />
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>


<script>
  import '../scripts/ramadan.ts';
</script>
