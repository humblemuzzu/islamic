---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import TopicHeader from '../components/TopicHeader.astro';
import MasailList from '../components/MasailList.astro';
import Footer from '../components/Footer.astro';
import { sawmMasail } from '../content/masail/sawm';
import '../styles/global.css';
---


<Layout title="Sawm — Fasting Rulings | Al-Masail">
  <Navbar />
  <main>
    <TopicHeader
      titleAr="صَوم"
      titleEn="Sawm — Fasting"
      subtitle={{ en: 'Fasting', ru: 'Roze ke Masail', ur: 'روزے کے مسائل' }}
      description={{ en: 'Rulings on fasting during menstruation, making up missed Ramadan fasts, and related questions for women.', ru: 'Haiz mein roze ke ahkaam, Ramzan ke chhoote hue rozon ki qaza, aur khawateen ke liye mutalliqa sawalaat.', ur: 'حیض میں روزے کے احکام، رمضان کے چھوٹے ہوئے روزوں کی قضا، اور خواتین کے لیے متعلقہ سوالات۔' }}
      masailCount={sawmMasail.length}
    />
    <MasailList masail={sawmMasail} />
  </main>
  <Footer />
</Layout>
