---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/counter.css';
---

<Layout title="Dhikr Counter | Al-Masail" description="Track your daily dhikr and durood with a beautiful, interactive counter. Persist your progress across sessions.">
  <Navbar />

  <!-- Hero Header -->
  <section class="counter-hero">
    <div class="pattern-overlay"></div>
    <div class="pattern-star"></div>

    <div class="counter-hero-content container">
      <div class="topic-title-block reveal reveal-delay-1">
        <span class="section-label">
          <T en="Daily Remembrance" ru="Rozana Dhikr" ur="روزانہ ذکر" />
        </span>
        <h1 class="topic-title-ar">عَدَّاد الذِّكْر</h1>
        <h2 class="topic-title-en">DHIKR COUNTER</h2>
      </div>

      <div class="topic-desc reveal reveal-delay-2">
        <p data-lang-block="en">Keep track of your daily adhkar and durood. Tap to count, switch between different dhikr, and watch your progress grow.</p>
        <p data-lang-block="ru">Apne rozana ke adhkar aur durood ka hisab rakhein. Tap karein, mukhtalif dhikr mein switch karein, aur apni taraqqi dekhein.</p>
        <p data-lang-block="ur">اپنے روزانہ کے اذکار اور درود کا حساب رکھیں۔ ٹیپ کریں، مختلف ذکر میں سوئچ کریں، اور اپنی ترقی دیکھیں۔</p>
      </div>
    </div>

    <div class="topic-hero-border">
      <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
        <line x1="0" y1="1" x2="1200" y2="1" stroke="url(#goldLineCounter)" stroke-width="1" stroke-dasharray="8 12 3 12" />
        <defs>
          <linearGradient id="goldLineCounter">
            <stop offset="0%" stop-color="transparent" />
            <stop offset="30%" stop-color="#C4A265" />
            <stop offset="70%" stop-color="#C4A265" />
            <stop offset="100%" stop-color="transparent" />
          </linearGradient>
        </defs>
      </svg>
    </div>
  </section>

  <!-- Theme Selector -->
  <section class="counter-themes-section">
    <div class="container">
      <div class="themes-scroll reveal" id="themesScroll">
        <button class="theme-pill active" data-theme="durood">
          <span class="theme-pill-ar">صَلِّ عَلٰى مُحَمَّدٍ</span>
          <span class="theme-pill-en">Durood</span>
        </button>
        <button class="theme-pill" data-theme="subhanallah">
          <span class="theme-pill-ar">سُبْحَانَ اللّٰه</span>
          <span class="theme-pill-en">SubhanAllah</span>
        </button>
        <button class="theme-pill" data-theme="alhamdulillah">
          <span class="theme-pill-ar">اَلْحَمْدُ لِلّٰه</span>
          <span class="theme-pill-en">Alhamdulillah</span>
        </button>
        <button class="theme-pill" data-theme="allahuakbar">
          <span class="theme-pill-ar">اَللّٰهُ اَكْبَر</span>
          <span class="theme-pill-en">Allahu Akbar</span>
        </button>
        <button class="theme-pill" data-theme="astagfirullah">
          <span class="theme-pill-ar">اَسْتَغْفِرُ اللّٰه</span>
          <span class="theme-pill-en">Astagfirullah</span>
        </button>
        <button class="theme-pill" data-theme="lailaha">
          <span class="theme-pill-ar">لَا اِلٰهَ اِلَّا اللّٰه</span>
          <span class="theme-pill-en">La Ilaha Illallah</span>
        </button>
        <button class="theme-pill" data-theme="lahawla">
          <span class="theme-pill-ar">لَا حَوْلَ وَلَا قُوَّة</span>
          <span class="theme-pill-en">La Hawla</span>
        </button>
        <button class="theme-pill" data-theme="yahayyu">
          <span class="theme-pill-ar">يَا حَيُّ يَا قَيُّوم</span>
          <span class="theme-pill-en">Ya Hayyu</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Counter Widget -->
  <section class="counter-widget-section">
    <div class="container">
      <div class="counter-card reveal">
        <!-- Dhikr text display -->
        <div class="dhikr-display">
          <p class="dhikr-arabic" id="dhikrArabic">اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ</p>
          <p class="dhikr-translit" id="dhikrTranslit">Allahumma Salli Ala Muhammad</p>
          <div class="dhikr-target" id="dhikrTarget" style="display: none;">
            <T en="Target:" ru="Hadaf:" ur="ہدف:" />
            <span id="targetNum"></span>
          </div>
        </div>

        <!-- SVG Progress Ring + Count -->
        <div class="counter-ring-wrap" id="counterRingWrap">
          <svg class="progress-ring" viewBox="0 0 200 200" id="progressRing" style="display: none;">
            <circle class="progress-ring-bg" cx="100" cy="100" r="88" />
            <circle class="progress-ring-fill" cx="100" cy="100" r="88" id="progressFill" />
          </svg>
          <div class="counter-number" id="counterNumber">0</div>
        </div>

        <!-- Tap Button -->
        <button class="tap-btn" id="tapBtn">
          <span class="tap-btn-inner">
            <T en="Tap" ru="Tap" ur="ٹیپ" />
          </span>
        </button>

        <!-- Reset -->
        <button class="reset-btn" id="resetBtn">
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
            <path d="M2 2v5h5M14 14V9H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M13.5 6.5A6 6 0 0 0 3 3.5L2 7m12 3l-1 3.5a6 6 0 0 1-10.5-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <T en="Reset Today" ru="Aaj Reset" ur="آج ری سیٹ" />
        </button>
      </div>
    </div>
  </section>

  <!-- Stats Dashboard -->
  <section class="counter-stats-section">
    <div class="container">
      <div class="divider-ornament reveal">
        <span>&#10022;</span>
      </div>

      <h3 class="stats-heading reveal">
        <T en="Your Progress" ru="Aap Ki Taraqqi" ur="آپ کی ترقی" />
      </h3>

      <div class="stats-grid reveal reveal-delay-1">
        <div class="stat-card">
          <span class="stat-number" id="statToday">0</span>
          <span class="stat-label"><T en="Today" ru="Aaj" ur="آج" /></span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="statWeek">0</span>
          <span class="stat-label"><T en="This Week" ru="Is Hafte" ur="اس ہفتے" /></span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="statMonth">0</span>
          <span class="stat-label"><T en="This Month" ru="Is Mahine" ur="اس مہینے" /></span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="statAllTime">0</span>
          <span class="stat-label"><T en="All Time" ru="Kul" ur="کل" /></span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>


<script>
  import '../scripts/counter.ts';
</script>
